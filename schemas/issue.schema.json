{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://seoul-atlas/schemas/issue.schema.json",
  "title": "IssuesPayload",
  "description": "ElectionIssues and DistrictIssues share the same shape, with district_issues adding a district_id.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/ElectionIssues" },
    { "$ref": "#/$defs/DistrictIssues" }
  ],
  "$defs": {
    "IssueEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tag", "label", "weight"],
      "properties": {
        "tag": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "Must exist in Issue Taxonomy"
        },
        "label": { "type": "string", "minLength": 1 },
        "weight": { "type": "number", "minimum": 0, "maximum": 1 },
        "description": { "type": "string" }
      }
    },
    "ElectionIssues": {
      "type": "object",
      "additionalProperties": false,
      "required": ["election_id", "summary", "issues", "confidence", "source_ids"],
      "properties": {
        "election_id": { "type": "string", "pattern": "^na-\\d{4}-\\d+$" },
        "summary": { "type": "string", "minLength": 1 },
        "issues": {
          "type": "array",
          "items": { "$ref": "#/$defs/IssueEntry" }
        },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "source_ids": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        }
      }
    },
    "DistrictIssues": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "election_id",
        "district_id",
        "summary",
        "issues",
        "confidence",
        "source_ids"
      ],
      "properties": {
        "election_id": { "type": "string", "pattern": "^na-\\d{4}-\\d+$" },
        "district_id": { "type": "string" },
        "summary": { "type": "string", "minLength": 1 },
        "issues": {
          "type": "array",
          "items": { "$ref": "#/$defs/IssueEntry" }
        },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "source_ids": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        }
      }
    }
  }
}
