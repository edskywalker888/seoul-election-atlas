{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://seoul-atlas/schemas/result.schema.json",
  "title": "DistrictResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "election_id",
    "district_id",
    "winner_party_id",
    "winner_candidate",
    "turnout_pct",
    "candidates"
  ],
  "properties": {
    "election_id": { "type": "string", "pattern": "^na-\\d{4}-\\d+$" },
    "district_id": { "type": "string" },
    "winner_party_id": { "type": "string" },
    "winner_candidate": { "type": "string", "minLength": 1 },
    "turnout_pct": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "Stored at full precision; rounded only at display"
    },
    "candidates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "party_id", "votes", "vote_pct"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "party_id": { "type": "string" },
          "votes": { "type": "integer", "minimum": 0 },
          "vote_pct": { "type": "number", "minimum": 0, "maximum": 100 }
        }
      }
    }
  }
}
