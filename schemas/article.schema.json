{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://seoul-atlas/schemas/article.schema.json",
  "title": "DriverArticle",
  "description": "Deep-dive article on a single election driver (issue tag). Long-form content with structured sections and keyed sentiment data points.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "election_id",
    "tag",
    "title",
    "thesis",
    "sections",
    "key_data_points",
    "confidence",
    "source_ids",
    "last_updated"
  ],
  "properties": {
    "election_id": { "type": "string", "pattern": "^na-\\d{4}-\\d+$" },
    "tag": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "Must match a tag in Issue Taxonomy and the matching election_issues entry"
    },
    "title": { "type": "string", "minLength": 1 },
    "subtitle": { "type": "string" },
    "thesis": {
      "type": "string",
      "minLength": 1,
      "description": "1–3 sentence plain-English summary of what the article argues"
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["heading", "paragraphs"],
        "properties": {
          "heading": { "type": "string", "minLength": 1 },
          "paragraphs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "key_data_points": {
      "type": "array",
      "description": "Specific anchored data points (poll numbers, approval ratings, search-trend peaks, etc.). Render as a sidebar.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "value", "source_id"],
        "properties": {
          "label": { "type": "string", "minLength": 1 },
          "value": { "type": "string", "minLength": 1 },
          "date": { "type": "string", "format": "date" },
          "source_id": { "type": "string" }
        }
      }
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "source_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "last_updated": { "type": "string", "format": "date" }
  }
}
