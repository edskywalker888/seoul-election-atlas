{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://seoul-atlas/schemas/market-snapshot.schema.json",
  "title": "MarketSnapshot",
  "description": "Time-stamped snapshot of a prediction market for an upcoming election. One file per (source, event, capture).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "captured_at",
    "source",
    "event_id",
    "event_url",
    "event_title",
    "end_date",
    "candidates"
  ],
  "properties": {
    "captured_at": { "type": "string", "format": "date-time" },
    "source": { "type": "string", "enum": ["polymarket", "kalshi"] },
    "event_id": { "type": "string", "minLength": 1 },
    "event_slug": { "type": "string" },
    "event_url": { "type": "string", "format": "uri" },
    "event_title": { "type": "string", "minLength": 1 },
    "end_date": { "type": "string", "format": "date-time" },
    "total_volume_usd": { "type": "number", "minimum": 0 },
    "total_liquidity_usd": { "type": "number", "minimum": 0 },
    "candidates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "prob"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "name_ko": { "type": "string" },
          "party_id": { "type": "string" },
          "market_id": { "type": "string" },
          "prob": { "type": "number", "minimum": 0, "maximum": 1 },
          "yes_bid": { "type": "number", "minimum": 0, "maximum": 1 },
          "yes_ask": { "type": "number", "minimum": 0, "maximum": 1 },
          "last_price": { "type": "number", "minimum": 0, "maximum": 1 },
          "volume_usd": { "type": "number", "minimum": 0 }
        }
      }
    },
    "method_notes": { "type": "string" }
  }
}
