{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://seoul-atlas/schemas/salience-snapshot.schema.json",
  "title": "SalienceSnapshot",
  "description": "Time-stamped snapshot of top political topics with per-party sentiment (DPK + PPP) and salience scores. One file per capture (once daily).",
  "type": "object",
  "additionalProperties": false,
  "required": ["captured_at", "method", "topics"],
  "properties": {
    "captured_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp of capture"
    },
    "method": {
      "type": "string",
      "enum": ["llm_synthesis", "rule_based", "manual_demo", "bigkinds", "datalab"],
      "description": "How the snapshot was produced"
    },
    "model": {
      "type": "string",
      "description": "Model identifier when method=llm_synthesis"
    },
    "source_urls": {
      "type": "array",
      "items": { "type": "string", "format": "uri" }
    },
    "topics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["rank", "topic_en", "topic_ko", "summary", "salience"],
        "properties": {
          "rank": { "type": "integer", "minimum": 1 },
          "topic_en": { "type": "string", "minLength": 1 },
          "topic_ko": { "type": "string", "minLength": 1 },
          "summary": { "type": "string", "minLength": 1 },
          "sentiment": {
            "type": "string",
            "enum": ["positive", "negative", "neutral", "mixed"],
            "description": "Legacy single-axis sentiment (DPK perspective). Optional; superseded by sentiment_dpk."
          },
          "sentiment_score": {
            "type": "number",
            "minimum": -1,
            "maximum": 1,
            "description": "Legacy. Optional; superseded by sentiment_score_dpk."
          },
          "sentiment_dpk": {
            "type": "string",
            "enum": ["positive", "negative", "neutral", "mixed"],
            "description": "Tone of coverage toward 더불어민주당 (DPK)."
          },
          "sentiment_score_dpk": {
            "type": "number",
            "minimum": -1,
            "maximum": 1
          },
          "sentiment_ppp": {
            "type": "string",
            "enum": ["positive", "negative", "neutral", "mixed"],
            "description": "Tone of coverage toward 국민의힘 (PPP)."
          },
          "sentiment_score_ppp": {
            "type": "number",
            "minimum": -1,
            "maximum": 1
          },
          "salience": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Relative dominance among the captured topics. Higher = more attention."
          },
          "issue_tag": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$",
            "description": "Optional cross-link to Issue Taxonomy"
          },
          "evidence_headlines": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["title"],
              "properties": {
                "title": { "type": "string", "minLength": 1 },
                "outlet": { "type": "string" },
                "url": { "type": "string", "format": "uri" }
              }
            }
          }
        }
      }
    },
    "method_notes": { "type": "string" }
  }
}
